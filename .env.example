# foundry-research environment variables
# Copy to .env and fill in your values, or set these in your shell profile.
# This file is not auto-loaded — set vars manually or use a tool like direnv.
# Config precedence: env vars > ~/.deep-research/config.json > session .config.json
# See docs/configuration.md for full details.

# ─── Web Search Providers (set at least one) ───
# These power web search during research sessions.

TAVILY_API_KEY=tvly-...
# PERPLEXITY_API_KEY=pplx-...
# LINKUP_API_KEY=...
# EXA_API_KEY=...
# GENSEE_API_KEY=...

# ─── Academic Provider Keys (all optional) ───
# These increase rate limits or unlock specific providers.

# SEMANTIC_SCHOLAR_API_KEY=...
# OPENALEX_API_KEY=...
# UNPAYWALL_EMAIL=you@example.com
# NCBI_API_KEY=...
# GITHUB_TOKEN=ghp_...
# SEC_EDGAR_EMAIL=you@example.com
# CORE_API_KEY=...
# OSF_TOKEN=...

# ─── Anna's Archive (optional, requires paid membership) ───
# Enables faster downloads via the fast_download API.
# Without this, Anna's Archive still works via web scraping (free).
# ANNAS_SECRET_KEY=...

# ─── Grey Source Control ───
# Comma-separated list of cascade sources to skip.
# Sources: openalex, unpaywall, arxiv, pmc, osf, annas_archive, scihub
# To disable shadow libraries:
# DEEP_RESEARCH_DISABLED_SOURCES=annas_archive,scihub
