#!/usr/bin/env bash
# LLM relevance scoring wrapper — auto-activates venv and delegates to triage-relevance.
set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=bootstrap-venv.sh
source "$SKILL_DIR/bootstrap-venv.sh"

exec "$VENV_DIR/bin/python" "$SKILL_DIR/scripts/triage-relevance" "$@"
