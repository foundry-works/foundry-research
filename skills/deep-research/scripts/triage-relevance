#!/usr/bin/env python3
"""LLM-powered abstract relevance scoring for source triage.

Uses Claude (Haiku) via the `claude` CLI to score how relevant each source's
abstract is to the research brief. Writes relevance_score (0-1) and
relevance_rationale back to state.db, so cmd_triage can use LLM scores
instead of keyword matching.

Why this exists: Keyword matching on titles lets high-citation off-topic papers
(e.g., "SPIRIT 2013" at 6932 cites) outrank directly relevant papers with
moderate citations. LLM scoring catches semantic relevance that keyword overlap
misses — "emotion regulation in preschoolers" is highly relevant to a
temperament measurement review but shares few literal keywords.
"""

import argparse
import json
import os
import shutil
import sqlite3
import subprocess
import sys
from textwrap import dedent

# Add parent directory so _shared imports work when run from any location
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from _shared.config import get_session_dir
from _shared.output import error_response, log, set_quiet, success_response


def _connect(session_dir: str) -> sqlite3.Connection:
    db_path = os.path.join(session_dir, "state.db")
    if not os.path.exists(db_path):
        error_response([f"state.db not found in {session_dir}"])
    conn = sqlite3.connect(f"file:{db_path}", uri=True)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA busy_timeout=20000")
    return conn


def _get_brief(conn: sqlite3.Connection, session_id: str) -> dict | None:
    row = conn.execute("SELECT * FROM brief WHERE session_id = ?", (session_id,)).fetchone()
    if not row:
        return None
    return {"scope": row["scope"], "questions": json.loads(row["questions"])}


def _get_unscored_sources(conn: sqlite3.Connection, session_id: str, top_n: int) -> list[dict]:
    """Get sources that have abstracts but no relevance_score yet."""
    rows = conn.execute(
        "SELECT id, title, abstract FROM sources "
        "WHERE session_id = ? AND abstract IS NOT NULL AND abstract != '' "
        "AND relevance_score IS NULL "
        "ORDER BY citation_count DESC NULLS LAST "
        "LIMIT ?",
        (session_id, top_n)
    ).fetchall()
    return [{"id": r["id"], "title": r["title"], "abstract": r["abstract"]} for r in rows]


def _format_prompt(brief: dict, sources: list[dict]) -> str:
    """Build the prompt for Haiku: brief context + numbered abstracts → JSON scores."""
    questions = brief["questions"]
    if isinstance(questions, list):
        q_lines = []
        for i, q in enumerate(questions, 1):
            text = q if isinstance(q, str) else q.get("text", str(q))
            q_lines.append(f"  Q{i}: {text}")
        q_block = "\n".join(q_lines)
    else:
        q_block = str(questions)

    source_block = []
    for i, s in enumerate(sources, 1):
        # Truncate abstract to ~300 words to keep prompt size reasonable
        abstract = s["abstract"]
        words = abstract.split()
        if len(words) > 300:
            abstract = " ".join(words[:300]) + "..."
        source_block.append(f"[{s['id']}] {s['title']}\n{abstract}")

    sources_text = "\n\n".join(source_block)

    return dedent(f"""\
You are scoring academic paper abstracts for relevance to a research brief.

## Research Brief
**Scope:** {brief['scope']}

**Questions:**
{q_block}

## Sources to Score
{sources_text}

## Instructions
For each source, output a JSON object with:
- "id": the source ID (e.g., "src-001")
- "score": float 0.0 (completely irrelevant) to 1.0 (directly addresses a research question)
- "rationale": one sentence explaining the relevance judgment
- "questions": list of question numbers this source could address (e.g., ["Q1", "Q3"])

Scoring guide:
- 0.0-0.2: Off-topic or tangentially related (different domain, different population, methodology-only)
- 0.3-0.5: Partially relevant (related domain but doesn't directly address any question)
- 0.6-0.8: Relevant (addresses one or more questions with useful evidence)
- 0.9-1.0: Highly relevant (directly and substantially addresses a core question)

Output ONLY a JSON array of objects. No explanation, no markdown fences, just the JSON array.""")


def _call_claude(prompt: str) -> list[dict] | None:
    """Call claude CLI in headless mode with Haiku model. Returns parsed JSON or None on failure."""
    try:
        result = subprocess.run(
            ["claude", "-p", prompt, "--model", "haiku", "--output-format", "json"],
            capture_output=True, text=True, timeout=120
        )
        if result.returncode != 0:
            log(f"claude CLI failed (exit {result.returncode}): {result.stderr[:300]}", level="warn")
            return None

        # The --output-format json wraps output in {"result": "...", ...}
        # The actual content is in the result field
        try:
            outer = json.loads(result.stdout)
            content = outer.get("result", result.stdout)
        except json.JSONDecodeError:
            content = result.stdout

        # Parse the inner JSON array from the content
        if isinstance(content, str):
            # Strip markdown fences if present
            content = content.strip()
            if content.startswith("```"):
                lines = content.split("\n")
                # Remove first and last fence lines
                lines = [l for l in lines if not l.strip().startswith("```")]
                content = "\n".join(lines)
            scores = json.loads(content)
        else:
            scores = content

        if not isinstance(scores, list):
            log(f"Expected JSON array from claude, got {type(scores).__name__}", level="warn")
            return None

        return scores

    except subprocess.TimeoutExpired:
        log("claude CLI timed out after 120s", level="warn")
        return None
    except (json.JSONDecodeError, KeyError) as e:
        log(f"Failed to parse claude response: {e}", level="warn")
        return None
    except FileNotFoundError:
        log("claude CLI not found — install Claude Code or add to PATH", level="warn")
        return None


def _write_scores(conn: sqlite3.Connection, scores: list[dict]) -> int:
    """Write relevance scores back to state.db. Returns count of rows updated."""
    updated = 0
    for entry in scores:
        src_id = entry.get("id")
        score = entry.get("score")
        rationale = entry.get("rationale", "")
        questions = entry.get("questions", [])

        if src_id is None or score is None:
            continue

        # Clamp score to [0, 1]
        try:
            score = max(0.0, min(1.0, float(score)))
        except (ValueError, TypeError):
            continue

        # Append matched questions to rationale for context
        if questions:
            q_str = ", ".join(str(q) for q in questions)
            rationale = f"{rationale} [{q_str}]" if rationale else f"[{q_str}]"

        conn.execute(
            "UPDATE sources SET relevance_score = ?, relevance_rationale = ? WHERE id = ?",
            (score, rationale, src_id)
        )
        updated += 1

    conn.commit()
    return updated


def main():
    parser = argparse.ArgumentParser(description="LLM-powered abstract relevance scoring")
    parser.add_argument("--top", type=int, default=60, help="Max sources to score (default 60)")
    parser.add_argument("--batch-size", type=int, default=15, help="Abstracts per LLM call (default 15)")
    parser.add_argument("--session-dir", default=None, help="Session directory (auto-discovered if omitted)")
    parser.add_argument("--quiet", action="store_true", help="Suppress stderr log output")
    args = parser.parse_args()

    if args.quiet:
        set_quiet(True)

    # Check claude CLI is available before doing any DB work
    if not shutil.which("claude"):
        error_response(["claude CLI not found — cannot run LLM relevance scoring. "
                        "Triage will fall back to keyword matching."])

    session_dir = get_session_dir(args)
    conn = _connect(session_dir)

    session_id = conn.execute("SELECT id FROM sessions LIMIT 1").fetchone()
    if not session_id:
        error_response(["No session found. Run init first."])
    session_id = session_id["id"]

    brief = _get_brief(conn, session_id)
    if not brief:
        error_response(["No brief found. Run set-brief first."])

    sources = _get_unscored_sources(conn, session_id, args.top)
    if not sources:
        success_response({
            "scored": 0,
            "skipped": 0,
            "message": "No unscored sources with abstracts found"
        })
        return

    log(f"Scoring {len(sources)} sources in batches of {args.batch_size}")

    total_scored = 0
    total_failed = 0
    batch_count = 0

    for i in range(0, len(sources), args.batch_size):
        batch = sources[i:i + args.batch_size]
        batch_count += 1
        log(f"Batch {batch_count}: scoring {len(batch)} sources")

        prompt = _format_prompt(brief, batch)
        scores = _call_claude(prompt)

        if scores is None:
            total_failed += len(batch)
            log(f"Batch {batch_count} failed — {len(batch)} sources unscored", level="warn")
            continue

        updated = _write_scores(conn, scores)
        total_scored += updated
        total_failed += len(batch) - updated
        log(f"Batch {batch_count}: {updated}/{len(batch)} scores written")

    conn.close()

    success_response({
        "scored": total_scored,
        "failed": total_failed,
        "batches": batch_count,
        "total_candidates": len(sources),
    })


if __name__ == "__main__":
    main()
