#!/usr/bin/env bash
# Crossref DOI enrichment CLI wrapper — auto-activates venv and delegates to enrich.py.
set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=bootstrap-venv.sh
source "$SKILL_DIR/bootstrap-venv.sh"

exec "$VENV_DIR/bin/python" "$SKILL_DIR/scripts/enrich.py" "$@"
