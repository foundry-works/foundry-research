#!/usr/bin/env bash
# Unified search CLI wrapper — auto-activates venv and delegates to search.py.
set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=bootstrap-venv.sh
source "$SKILL_DIR/bootstrap-venv.sh"

exec "$VENV_DIR/bin/python" "$SKILL_DIR/scripts/search.py" "$@"
